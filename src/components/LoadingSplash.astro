---
---

<div id="loading-splash" class="loading-splash" aria-hidden="true" role="status">
  <div class="loading-splash__inner">
    <div class="loading-splash__logo">
      <span class="loading-splash__f">F</span>
      <div class="loading-splash__bar"></div>
      <span class="loading-splash__name">Forma Studio</span>
    </div>
    <p class="loading-splash__tagline">Brand · Identity · Direction</p>
  </div>
</div>

<style>
  .loading-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .loading-splash__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    opacity: 0;
    transform: translateY(1rem);
  }

  .loading-splash__logo {
    display: flex;
    align-items: flex-end;
    gap: 0.8rem;
  }

  .loading-splash__f {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--color-paper);
  }

  .loading-splash__bar {
    width: 3rem;
    height: 3px;
    background: var(--color-red);
    margin-bottom: 0.5rem;
  }

  .loading-splash__name {
    font-family: var(--font-sans);
    font-size: clamp(0.7rem, 1.5vw, 1rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-paper) 60%, transparent);
    align-self: flex-end;
    padding-bottom: 0.3rem;
  }

  .loading-splash__tagline {
    font-size: var(--text-xs);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-paper) 35%, transparent);
  }
</style>

<script>
  async function initSplash() {
    const splash = document.getElementById('loading-splash');
    if (!splash) return;

    const seen = sessionStorage.getItem('forma-splash-seen');
    if (seen) {
      splash.style.display = 'none';
      return;
    }

    try {
      const { gsap } = await import('gsap');
      const inner = splash.querySelector('.loading-splash__inner') as HTMLElement;

      const tl = gsap.timeline({
        onComplete: () => { sessionStorage.setItem('forma-splash-seen', '1'); },
      });

      tl.to(inner, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
        .to(inner, { opacity: 0, y: -16, duration: 0.55, ease: 'power2.in' }, '+=0.7')
        .to(splash, { opacity: 0, duration: 0.45, ease: 'power2.inOut',
          onComplete: () => { splash.style.display = 'none'; } }, '-=0.2');
    } catch {
      const inner = splash.querySelector('.loading-splash__inner') as HTMLElement | null;
      if (inner) { inner.style.opacity = '1'; inner.style.transform = 'none'; }
      splash.style.transition = 'opacity 0.45s ease';
      setTimeout(() => {
        splash.style.opacity = '0';
        splash.addEventListener('transitionend', () => {
          splash.style.display = 'none';
          sessionStorage.setItem('forma-splash-seen', '1');
        }, { once: true });
      }, 1400);
    }
  }

  initSplash();
</script>
