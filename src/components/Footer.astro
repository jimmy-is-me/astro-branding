---
interface NavLink { label: string; href: string; }
interface SocialLink { label: string; href: string; icon: string; }
interface Props {
  siteName?: string;
  navLinks?: NavLink[];
  socialLinks?: SocialLink[];
  copyrightYear?: number;
}

const {
  siteName = 'Forma Studio',
  navLinks = [],
  socialLinks = [],
  copyrightYear = new Date().getFullYear(),
} = Astro.props;

function withBase(path: string): string {
  if (/^(?:[a-z]+:)?\/\//i.test(path)) return path;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-brand-block">
      <div class="footer-logo">
        <span class="footer-logo__f">F</span>
        <div class="footer-logo__bar"></div>
      </div>
      <p class="footer-tagline">Brand strategy, identity design,<br />and creative direction.</p>
      <div class="footer-social">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="footer-social-link"
            aria-label={link.label}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div class="footer-nav-block">
      <p class="footer-nav-label">Navigate</p>
      <nav class="footer-nav" aria-label="Footer navigation">
        {navLinks.map((link) => (
          <a href={withBase(link.href)} class="footer-nav-link">{link.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-contact-block">
      <p class="footer-nav-label">Get in touch</p>
      <p class="footer-contact-email">hello@formastudio.co</p>
      <p class="footer-contact-info">Based in Taipei, Taiwan<br />Available worldwide</p>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">&copy; {copyrightYear} {siteName}. All rights reserved.</p>
    <a href={withBase('/privacy')} class="footer-privacy">Privacy Policy</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    max-width: var(--layout-max-width);
    margin-inline: auto;
    padding: clamp(3rem, 6vw, 5rem) var(--layout-padding);
  }

  .footer-logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    margin-bottom: 1.2rem;
  }

  .footer-logo__f {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-paper);
  }

  .footer-logo__bar {
    width: 2rem;
    height: 2px;
    background: var(--color-red);
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-paper) 60%, transparent);
    margin-bottom: 1.5rem;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.2rem;
  }

  .footer-social-link {
    font-size: var(--text-xs);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-paper) 55%, transparent);
    transition: color var(--transition-fast);
  }

  .footer-social-link:hover { color: var(--color-paper); }

  .footer-nav-label {
    font-size: var(--text-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-paper) 40%, transparent);
    margin-bottom: 1.2rem;
  }

  .footer-nav {
    display: grid;
    gap: 0.7rem;
  }

  .footer-nav-link {
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--color-paper) 65%, transparent);
    transition: color var(--transition-fast);
  }

  .footer-nav-link:hover { color: var(--color-paper); }

  .footer-contact-email {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    color: var(--color-paper);
    margin-bottom: 0.8rem;
  }

  .footer-contact-info {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: color-mix(in srgb, var(--color-paper) 55%, transparent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--layout-max-width);
    margin-inline: auto;
    padding: 1.4rem var(--layout-padding);
    border-top: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
  }

  .footer-copyright, .footer-privacy {
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--color-paper) 35%, transparent);
  }

  .footer-privacy { transition: color var(--transition-fast); }
  .footer-privacy:hover { color: var(--color-paper); }

  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; padding-inline: var(--layout-padding-sm); }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; padding-inline: var(--layout-padding-sm); }
  }
</style>
