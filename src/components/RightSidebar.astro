---
interface SocialLink { label: string; href: string; icon: string; }
interface Props { socialLinks?: SocialLink[]; }
const { socialLinks = [] } = Astro.props;
---

<aside class="right-sidebar" aria-label="Social links">
  <div class="right-sidebar__inner">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        class="sidebar-social"
        aria-label={link.label}
        target={link.href.startsWith('http') ? '_blank' : undefined}
        rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</aside>

<style>
  .right-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: var(--layout-sidebar-right);
    height: 100vh;
    background-color: var(--color-cream);
    border-left: 1px solid var(--color-rule);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .right-sidebar__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .sidebar-social {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    white-space: nowrap;
    font-family: var(--font-sans);
    font-size: var(--text-sidebar);
    color: var(--color-ink-mid);
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
  }

  .sidebar-social:hover { color: var(--color-ink); }

  @media (max-width: 1024px) {
    .right-sidebar { display: none; }
  }
</style>
